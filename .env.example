# ============================================================
# HELP DESK — HEALTH & SAFETY
# Arquivo de Variaveis de Ambiente (.env.example)
# Copie para .env e preencha os valores reais
# ============================================================

# ── Ambiente ──────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:5173","http://localhost:8000"]

# ── PostgreSQL ────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://helpdesk_user:CHANGE_ME_STRONG_PASSWORD@localhost:5432/helpdesk_db
POSTGRES_USER=helpdesk_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=helpdesk_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@localhost:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ── JWT (Autenticacao) ────────────────────────────────────────
# Gerar chaves RS256: openssl genrsa -out private.pem 2048
#                     openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7
JWT_ALGORITHM=RS256
JWT_ISSUER=helpdesk.healthsafetytech.com

# ── MinIO (S3-compatible Storage) ─────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET
MINIO_BUCKET_NAME=helpdesk-attachments
MINIO_USE_SSL=false
MINIO_CONSOLE_PORT=9001

# ── LLM / IA — Provider Primario (OpenAI) ────────────────────
LLM_PRIMARY_PROVIDER=openai
OPENAI_API_KEY=sk-CHANGE_ME_OPENAI_KEY
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=1024
OPENAI_TEMPERATURE=0.3

# ── LLM / IA — Provider Fallback (Anthropic) ─────────────────
LLM_FALLBACK_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME_ANTHROPIC_KEY
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
ANTHROPIC_MAX_TOKENS=1024

# ── LLM — Configuracoes Gerais ───────────────────────────────
LLM_REQUEST_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2
LLM_FALLBACK_ENABLED=true

# ── SMTP (Email — FastAPI-Mail) ──────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_TLS=true
SMTP_SSL=false
SMTP_USER=helpdesk@healthsafetytech.com
SMTP_PASSWORD=CHANGE_ME_APP_PASSWORD
SMTP_FROM_NAME=Help Desk Health & Safety
SMTP_FROM_EMAIL=helpdesk@healthsafetytech.com

# ── ClamAV (Antivirus) ───────────────────────────────────────
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_SECONDS=30
CLAMAV_MAX_FILE_SIZE_MB=25

# ── WebSocket (FastAPI) ──────────────────────────────────────
WS_HEARTBEAT_INTERVAL=25
WS_MAX_CONNECTIONS=1000

# ── Celery (Filas de Tarefas) ────────────────────────────────
CELERY_BROKER_URL=redis://:CHANGE_ME_REDIS_PASSWORD@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:CHANGE_ME_REDIS_PASSWORD@localhost:6379/2
CELERY_DEFAULT_MAX_RETRIES=3
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=600

# ── Upload de Arquivos ───────────────────────────────────────
UPLOAD_MAX_FILE_SIZE_MB=25
UPLOAD_ALLOWED_EXTENSIONS=.pdf,.doc,.docx,.xls,.xlsx,.png,.jpg,.jpeg,.gif,.txt,.csv,.zip,.rar
UPLOAD_MAX_FILES_PER_TICKET=10

# ── SLA — Horario Comercial ──────────────────────────────────
SLA_BUSINESS_HOURS_START=08:00
SLA_BUSINESS_HOURS_END=18:00
SLA_BUSINESS_DAYS=1,2,3,4,5
SLA_TIMEZONE=America/Sao_Paulo

# ── Logs e Observabilidade (Loguru) ──────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_DIR=./logs
LOG_ROTATION=10 MB
LOG_RETENTION=30 days

# ── Rate Limiting (slowapi) ─────────────────────────────────
RATE_LIMIT_DEFAULT=100/15minutes
RATE_LIMIT_LOGIN=5/15minutes

# ── Seguranca ────────────────────────────────────────────────
BCRYPT_ROUNDS=12
SECRET_KEY=CHANGE_ME_SECRET_KEY_MIN_32_CHARS

# ── Frontend (Vite) ──────────────────────────────────────────
VITE_API_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000/ws
VITE_APP_NAME=Help Desk Health & Safety
VITE_APP_VERSION=1.0.0

# ── Docker — Producao (override no .env.production) ──────────
# DOMAIN=helpdesk.healthsafetytech.com
# SSL_EMAIL=ti@healthsafetytech.com
# NGINX_CLIENT_MAX_BODY_SIZE=25M
# UVICORN_WORKERS=4
# GUNICORN_WORKERS=4
